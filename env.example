# Local development — copy to `.env` and fill in values.
#   cp env.example .env
# Source: Partner Dashboard → WishMe (or your app) → Settings → Credentials.
#
# Repo: https://github.com/whiteHatpro/wishme

# App Client ID (same as "Client ID" in Partner Dashboard)
SHOPIFY_API_KEY=

# App Client secret
SHOPIFY_API_SECRET=

# Must match `shopify.app.toml` → [access_scopes] scopes=
SCOPES=read_customers,write_customers,read_products,read_orders,write_script_tags,read_script_tags,read_themes,write_themes

# Application URL — during `shopify app dev` the CLI sets a tunnel URL.
# Leave empty locally until the dev server prints it, or paste the preview URL.
SHOPIFY_APP_URL=

# Optional: restrict to a dev store hostname when using `shopify app dev --store`
# SHOP_CUSTOM_DOMAIN=your-store.myshopify.com

# --- Database (PostgreSQL required) ---
# Local: `docker compose up -d` then set DATABASE_URL to match postgres credentials in docker-compose.yml (see docs/QA_DATABASE.md).
DATABASE_URL=
#
# Shared QA: paste your host’s connection string from their dashboard into `.env` only (never commit).
