{% comment %}
  WishmaX — Add this block on a Page (e.g. /pages/wishlist) via the theme editor.
{% endcomment %}
<div class="page-width" style="padding: 40px 20px; max-width: 1200px; margin: 0 auto;">
  <h1 style="margin-bottom: 24px;">{{ block.settings.heading }}</h1>
  <div id="wishmax-page-container">
    <p style="color: #6d7175;">Loading your wishlist…</p>
  </div>
</div>

<script>
  window.__WISHMAX_APP_URL__ = {{ shop.metafields.wishmax.app_url | json | default: '' }};
  window.__WISHMAX_CUSTOMER_ID__ = {{ customer.id | json | default: 'null' }};
  window.__WISHMAX_EMPTY_MSG__ = {{ block.settings.empty_message | json }};
  window.__WISHMAX_PAGE_HANDLE__ = {{ block.settings.page_handle | json }};
</script>
<script src="{{ 'wishmax-page.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "WishmaX wishlist page",
  "target": "section",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "page_handle",
      "label": "Wishlist page handle (for deep links)",
      "default": "wishlist",
      "info": "Should match the page handle in Online Store → Pages (e.g. wishlist → /pages/wishlist)."
    },
    {
      "type": "textarea",
      "id": "empty_message",
      "label": "Empty state message",
      "default": "Your wishlist is empty."
    }
  ]
}
{% endschema %}
