{% comment %}
  WishmaX — Theme app embed: enable under Theme settings → App embeds.
{% endcomment %}

<script>
  window.__WISHMAX_APP_URL__ = {{ shop.metafields.wishmax.app_url | json | default: '' }};
  window.__WISHMAX_CUSTOMER_ID__ = {{ customer.id | json | default: 'null' }};
  window.__WISHMAX_PRODUCT_ID__ = {{ product.id | json | default: 'null' }};
</script>

<script src="{{ 'wishmax.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "WishmaX",
  "target": "body",
  "settings": []
}
{% endschema %}
